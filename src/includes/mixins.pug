//- Modal shell — wraps content in a Bulma modal card
mixin modal(flag, titleKey, toggle, vShow)
  - var cls = '{\'is-active\': ' + flag + '}'
  - var titleHtml = '{{ translate(\'' + titleKey + '\') }}'
  .modal(v-bind:class=cls)&attributes(vShow ? { 'v-show': vShow } : {})
    .modal-background
    .modal-card
      header.modal-card-head
        p.modal-card-title.no-select !{titleHtml}
        button.delete(aria-label='close' @click=toggle)
      block

//- HTML / Markdown / Preview buttons for policy modals
mixin outputButtons(contentId, textareaId)
  button.button.is-primary(@click=`getHtml('${contentId}','${textareaId}')`) {{ translate('modal.btn.html') }}
  button.button.is-primary(@click=`getMarkdown('${contentId}', '${textareaId}')`) {{ translate('modal.btn.markdown') }}
  button.button.is-primary(v-if='contentRenderType!=1' @click='preview()') {{ translate('modal.btn.preview') }}

//- Generator attribution
mixin attribution(type)
  - var attrExpr = "translate('modal.attribution." + type + "')"
  hr
  p
    span(v-html=attrExpr)
    a(href='https://app-privacy-policy-generator.nisrulz.com/' target='_blank' rel='noopener noreferrer') App Privacy Policy Generator

//- Flycricket deploy button (compile-time conditional on flycricket var)
mixin flycricketDeploy(method)
  if (flycricket)
    div(style='flex:1')
      button.button.is-info(@click=method style='float:right;')
        | {{ translate('modal.btn.deployFlycricket') }}

//- Wizard progress bar — is-primary for final step, is-link otherwise
mixin wizardProgress(value)
  - var cls = value === 100 ? 'is-primary' : 'is-link'
  progress.progress(class=`is-small ${cls}` value=value max='100')

//- Wizard mobile logo — hidden on desktop
mixin wizardMobileLogo()
  p.is-hidden-desktop
    a(href='https://github.com/nisrulz/app-privacy-policy-generator#app-privacy-policy-generator' target='_blank' rel='noopener noreferrer')
      img.is-size-1(src='/images/text_logo.svg')

//- Wizard sidebar image
mixin wizardSidebar()
  .column.is-information.is-hidden-touch
    a(href='https://github.com/nisrulz/app-privacy-policy-generator#app-privacy-policy-generator' target='_blank' rel='noopener noreferrer')
      img.center-block.sidebar-img(src='/images/app_graphics/side_image.png')
