section#step-2.columns(v-if='wizardStep==2')
    .column.card
        .card-content
            +wizardMobileLogo
            +wizardProgress(16)
            .scrollable.content
                .control
                    | Type: 
                    label.radio
                        input(
                            v-model="typeOfPolicyInt" 
                            value="1" 
                            type="radio"
                            )
                        |   Simple
                    if noTracking
                        label.radio
                            input(
                                v-model="typeOfPolicyInt" 
                                value="2" 
                                type="radio"
                                )
                            |   No Tracking
                    if gdpr
                        label.radio
                            input(
                                v-model="typeOfPolicyInt" 
                                value="3" 
                                type="radio"
                                )
                            |   GDPR
                br
                .control
                    .field
                        label.label App Name
                        .control
                            input#appName.input(
                                v-bind:class="{ 'is-danger': (appName.length == 0) }" 
                                placeholder="Awesome App Name" 
                                v-model="appName" 
                                required="" 
                                type="text"
                                )
                        p.help.has-text-grey(v-show="!(appName.length == 0)") Name of the app or service covered by the generated document.
                        p.help(v-bind:class="{ 'is-danger': (appName.length == 0) }" v-show="(appName.length == 0)") Application Name is required.
                br
                .control
                    .field
                        label.label Contact Information
                        .control
                            input#appContact.input(
                                v-bind:class="{ 'is-danger': (appContact.length == 0) }" 
                                placeholder="Email Address" 
                                v-model="appContact" 
                                required="" 
                                type="email"
                                )
                        p.help.has-text-grey(v-show="!(appContact.length == 0)") Email address for privacy, legal, and support inquiries.
                        p.help(v-bind:class="{ 'is-danger': (appContact.length == 0) }" v-show="(appContact.length == 0)") Email address is required.
                br
                .control(v-show="typeOfPolicyInt==3")
                    .field
                        label.label EU Representative (optional)
                        .control
                            input#euRepresentative.input(
                                placeholder="EU Representative Name and Contact"
                                v-model="euRepresentative" 
                                type="text"
                                )
                        p.help.has-text-grey Name and contact details of your EU representative, if required under GDPR Article 27.
        footer.card-footer
            a.card-footer-item(@click='prevStep') Previous
            a.card-footer-item(@click='nextStep' :class="{ 'is-disabled': !canAdvance }") Next
    +wizardSidebar
