section#step-6.columns(v-if="wizardStep==6")
    .column.card
        .card-content
            +wizardMobileLogo
            +wizardProgress(70)
            .scrollable.content
                .control
                    | {{ translate('wizard.step6.selectOwner') }}
                    span.tag.is-primary.is-light {{typeOfDev}}
                    br
                    label.radio
                        input(
                            v-model="typeOfDev" 
                            value="Individual" 
                            type="radio"
                            )
                        |   {{ translate('wizard.step6.individual') }}
                    br
                    label.radio
                        input(
                            v-model="typeOfDev" 
                            value="Company" 
                            type="radio"
                            )
                        |   {{ translate('wizard.step6.company') }}
                br
                .control(v-if="typeOfDev=='Company'")
                    .field
                        label.label(for="companyName") {{ translate('wizard.step6.companyName') }}
                        .control
                            input#companyName.input(
                                v-bind:class="{ 'is-danger': (companyName.length == 0 && typeOfDev=='Company') }"
                                :placeholder="translate('wizard.step6.companyNamePlaceholder')" 
                                v-model="companyName" 
                                required=""
                                type="text"
                                )
                        p.help(v-bind:class="{ 'is-danger': (companyName.length == 0 && typeOfDev=='Company') }" v-show="(companyName.length == 0 && typeOfDev=='Company')") {{ translate('wizard.step6.companyNameRequired') }}
                .control(v-if="typeOfDev=='Individual'")
                    .field
                        label.label(for="devName") {{ translate('wizard.step6.devName') }}
                        .control
                            input#devName.input(
                                v-bind:class="{ 'is-danger': (devName.length == 0 && typeOfDev=='Individual') }"
                                :placeholder="translate('wizard.step6.devNamePlaceholder')" 
                                v-model="devName" 
                                required=""
                                type="text"
                                )
                        p.help(v-bind:class="{ 'is-danger': (devName.length == 0 && typeOfDev=='Individual') }" v-show="(devName.length == 0 && typeOfDev=='Individual')") {{ translate('wizard.step6.devNameRequired') }}
        footer.card-footer
            a.card-footer-item(@click='prevStep') {{ translate('wizard.step6.previous') }}
            a.card-footer-item(@click='nextStep' :class="{ 'is-disabled': !canAdvance }") {{ translate('wizard.step6.next') }}
    +wizardSidebar