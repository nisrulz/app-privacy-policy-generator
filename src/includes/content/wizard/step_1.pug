    a.title(href='https://github.com/nisrulz/app-privacy-policy-generator#app-privacy-policy-generator' target='_blank' rel='noopener noreferrer' :aria-label='translate("meta.title")')
    img.center-block.hero-image(src='/images/app_graphics/side_image.png' :alt='translate("wizard.step1.heroAlt")' width='2024' height='1132' fetchpriority='high')
    p.is-size-8.mt-2
      | {{ translate('wizard.step1.tagline') }}
    p.mt-2
      a(href='https://github.com/nisrulz/app-privacy-policy-generator#app-privacy-policy-generator' target='_blank' rel='noopener noreferrer') {{ translate('wizard.step1.freeAndOpenSource') }}
