      span.heart ♥️ 
      |  {{ translate('wizard.step1.by') }} 
      a(href='http://www.nisrulz.com/' target='_blank' rel='noopener noreferrer') Nishant
      |  {{ translate('wizard.step1.and') }} 
      a(href='https://github.com/nisrulz/app-privacy-policy-generator/graphs/contributors' target='_blank' rel='noopener noreferrer') {{ translate('wizard.step1.contributors') }}
