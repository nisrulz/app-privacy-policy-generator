.modal(v-bind:class="{ 'is-active': showDisclaimerModal }")
    .modal-background
    .modal-card
        header.modal-card-head
            p.modal-card-title.no-select {{ translate('disclaimer.title') }}
            button.delete(aria-label='close' @click='toggleDisclaimerModalVisibility')
        section.modal-card-body
            p {{ translate('disclaimer.text1') }}
            p {{ translate('disclaimer.text2') }}
            p {{ translate('disclaimer.text3') }}
            p {{ translate('disclaimer.text4') }}
            p {{ translate('disclaimer.text5') }}
        footer.modal-card-foot
            button.button.is-info(aria-label='close' @click='toggleDisclaimerModalVisibility')
                | {{ translate('modal.btn.ok') }}