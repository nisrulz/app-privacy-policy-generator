+modal('showGDPRPrivacyModal', 'modal.privacyGDPR.title', 'toggleGDPRPrivacyModalVisibility', 'typeOfPolicyInt==3')
        section.modal-card-body.modal-box
            #privacy_gdpr_content(v-show='contentRenderType==1')
                strong {{ $t('gdpr.title') }}

                p(v-html="$t('gdpr.intro')")

                br
                strong {{ $t('gdpr.controllerTitle') }}

                p {{ $t('gdpr.controllerText') }}
                ul
                    li(v-html="$t('gdpr.controllerName')")
                    li(v-if='businessAddress') {{ $t('gdpr.controllerAddress') }}
                    li(v-html="$t('gdpr.controllerEmail')")

                p {{ $t('gdpr.controllerInquiry') }}

                p(v-if='euRepresentative') {{ $t('gdpr.euRepresentative') }}

                br
                strong {{ $t('gdpr.infoTitle') }}

                p {{ $t('gdpr.infoText1') }}

                p {{ $t('gdpr.infoText2') }}

                br
                strong {{ $t('gdpr.legalBasisTitle') }}

                p {{ $t('gdpr.legalBasisIntro') }}
                ul
                    li {{ $t('gdpr.legalBasis.contract') }}
                    li {{ $t('gdpr.legalBasis.consent') }}
                    li {{ $t('gdpr.legalBasis.legitimate') }}
                    li {{ $t('gdpr.legalBasis.obligation') }}

                br
                strong {{ $t('gdpr.cookiesTitle') }}

                p {{ $t('gdpr.cookiesText') }}

                br
                strong {{ $t('gdpr.automatedTitle') }}

                p {{ $t('gdpr.automatedText') }}

                br
                strong {{ $t('gdpr.autoCollectTitle') }}

                p(v-html="$t('gdpr.autoCollectText')")

                br
                strong {{ $t('gdpr.locationTitle') }}

                p(v-if='!isLocationTracked', v-html="$t('gdpr.locationNo')")
                div(v-if='isLocationTracked')
                    p {{ $t('gdpr.locationYes') }}
                    ul
                        li {{ $t('gdpr.locationGeo') }}
                        li {{ $t('gdpr.locationAnalytics') }}
                        li {{ $t('gdpr.locationThirdParty') }}

                br
                strong {{ $t('gdpr.aiTitle') }}
                p(v-if='!isAIUsed') {{ $t('gdpr.aiNo') }}
                div(v-if='isAIUsed')
                    p {{ $t('gdpr.aiYes') }}
                    ul
                        li {{ $t('gdpr.aiPersonalized') }}
                        li {{ $t('gdpr.aiRecommendations') }}
                        li {{ $t('gdpr.aiAutomated') }}
                        li {{ $t('gdpr.aiProtection') }}
                br
                strong {{ $t('gdpr.thirdPartyTitle') }}

                p {{ $t('gdpr.thirdPartyText') }}

                br
                strong {{ $t('gdpr.dataTransfersTitle') }}

                p {{ $t('gdpr.dataTransfersText') }}
                ul
                    li {{ $t('gdpr.dataTransfers.adequacy') }}
                    li {{ $t('gdpr.dataTransfers.scc') }}
                    li {{ $t('gdpr.dataTransfers.safeguards') }}

                p {{ $t('gdpr.dataTransfersNote') }}

                div(v-if='hasThirdPartyServicesSelected')
                    br
                    p {{ $t('gdpr.thirdPartyServicesText') }}
                    ul
                        li(v-for="item in enabledThirdPartyServicesWithPrivacy" :key="item.name")
                            a(:href='item.link.privacy' target='_blank' rel='noopener noreferrer') {{item.name}}
                p {{ $t('gdpr.disclosureText') }}
                    ul
                        li {{ $t('gdpr.disclosure.law') }}
                        li {{ $t('gdpr.disclosure.safety') }}
                        li {{ $t('gdpr.disclosure.providers') }}

                p {{ $t('gdpr.dpaText') }}

                br
                strong {{ $t('gdpr.optOutTitle') }}

                div(v-if='isMobileApp || isWindowsApp')
                    p(v-html="$t('gdpr.optOutUninstall')")
                div(v-if='isWebApp')
                    p(v-html="$t('gdpr.optOutCease')")
                p(v-html="$t('gdpr.optOutContact')")

                br
                strong {{ $t('gdpr.retentionTitle') }}

                p {{ $t('gdpr.retentionIntro') }}
                ul
                    li {{ $t('gdpr.retention.userData') }}
                    li {{ $t('gdpr.retention.autoData') }}
                    li {{ $t('gdpr.retention.aggregated') }}
                    li {{ $t('gdpr.retention.legal') }}

                p(v-html="$t('gdpr.retentionDeletion')")

                div(v-if='hasDataDeletion')
                    br
                    strong {{ $t('gdpr.dataDeletionTitle') }}
                    p(v-html="$t('gdpr.dataDeletionText')")
                    p {{ $t('gdpr.dataDeletionVerify') }}

                br
                strong {{ $t('gdpr.childrenTitle') }}

                p(v-html="$t('gdpr.childrenIntro')")
                div(v-if='hasThirdPartyServicesSelected')
                    br
                    p(v-html="$t('gdpr.childrenWithServices')")
                div(v-else)
                    br
                    p(v-html="$t('gdpr.childrenWithoutServices')")

                br
                strong {{ $t('gdpr.securityTitle') }}

                p {{ $t('gdpr.securityText') }}

                br
                strong {{ $t('gdpr.breachTitle') }}
                p {{ $t('gdpr.breachText') }}
                br
                strong {{ $t('gdpr.changesTitle') }}

                p {{ $t('gdpr.changesText') }}
                br
                p(v-html="$t('gdpr.changesPrev')")
                br
                p(v-html="$t('gdpr.effectiveDate')")

                br
                strong {{ $t('gdpr.gdprRightsTitle') }}

                p {{ $t('gdpr.gdprRightsIntro') }}
                ul
                    li {{ $t('gdpr.gdprRights.access') }}
                    li {{ $t('gdpr.gdprRights.rectification') }}
                    li {{ $t('gdpr.gdprRights.erasure') }}
                    li {{ $t('gdpr.gdprRights.restrict') }}
                    li {{ $t('gdpr.gdprRights.portability') }}
                    li {{ $t('gdpr.gdprRights.object') }}
                    li {{ $t('gdpr.gdprRights.withdraw') }}
                    li {{ $t('gdpr.gdprRights.automated') }}

                p {{ $t('gdpr.gdprRightsComplaint') }}
                    a(href='https://edpb.ec.europa.eu/about-edpb/members_en' target='_blank' rel='noopener noreferrer') https://edpb.ec.europa.eu/about-edpb/members_en
                p {{ $t('gdpr.gdprRightsICO') }}
                    a(href='https://ico.org.uk' target='_blank' rel='noopener noreferrer') https://ico.org.uk

                br
                strong {{ $t('gdpr.ccpaTitle') }}

                p {{ $t('gdpr.ccpaIntro') }}
                ul
                    li {{ $t('gdpr.ccpa.know') }}
                    li {{ $t('gdpr.ccpa.delete') }}
                    li {{ $t('gdpr.ccpa.correct') }}
                    li {{ $t('gdpr.ccpa.optOut') }}
                    li {{ $t('gdpr.ccpa.limit') }}
                    li {{ $t('gdpr.ccpa.nonDiscrimination') }}

                p(v-html="$t('gdpr.ccpaExercise')")

                br  
                strong {{ $t('gdpr.consentTitle') }}

                p {{ $t('gdpr.consentText') }}

                br
                strong {{ $t('gdpr.contactTitle') }}

                p(v-html="$t('gdpr.contactText')")

                p(v-html="$t('gdpr.contactDeletion')")
                +attribution('privacy policy')
            textarea#privacy_gdpr_txtarea.textarea(:aria-label='$t("gdpr.title") + $t("modal.textareaLabel")' onclick='this.focus();this.select()' readonly='readonly' v-show='contentRenderType==2')
        footer.modal-card-foot
            +outputButtons('privacy_gdpr_content', 'privacy_gdpr_txtarea')
            +flycricketDeploy('fc_deploy_gdpr()')
