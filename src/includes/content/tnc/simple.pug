+modal('showTermsModal', 'modal.terms.title', 'toggleTermsModalVisibility')
        section.modal-card-body.modal-box
            #tandc_content(v-show='contentRenderType==1')
                strong {{ $t('tnc.title') }}
                br 
                p(v-html="$t('tnc.intro')")
                br 
                p {{ $t('tnc.acceptance') }}

                br
                div(v-if='!isAppOpenSource()')
                    strong {{ $t('tnc.licenseTitle') }}
                    p(v-html="$t('tnc.licenseCommercial')")
                div(v-else)
                    strong {{ $t('tnc.licenseTitle') }}
                    p {{ $t('tnc.licenseOpenSource') }}

                br
                strong {{ $t('tnc.ipTitle') }}
                p {{ $t('tnc.ipText') }}
                br
                strong {{ $t('tnc.terminationTitle') }}
                p {{ $t('tnc.terminationBreach') }}
                br
                p {{ $t('tnc.terminationImmediate') }}
                br
                p {{ $t('tnc.terminationEffect') }}
                br
                p(v-html="$t('tnc.terminationAge')")
                div(v-if='!isAppOpenSource()')
                    br
                    p {{ $t('tnc.terminationNoDeriv') }}
                br
                strong {{ $t('tnc.ugcTitle') }}
                p {{ $t('tnc.ugcIntro') }}
                ul
                    li {{ $t('tnc.ugc.illegal') }}
                    li {{ $t('tnc.ugc.abusive') }}
                    li {{ $t('tnc.ugc.discrimination') }}
                    li {{ $t('tnc.ugc.spam') }}
                    li {{ $t('tnc.ugc.privacy') }}
                    li {{ $t('tnc.ugc.misleading') }}
                    li {{ $t('tnc.ugc.violence') }}
                br
                p {{ $t('tnc.ugc.rightsTitle') }}
                ul
                    li {{ $t('tnc.ugc.remove') }}
                    li {{ $t('tnc.ugc.suspend') }}
                    li {{ $t('tnc.ugc.lawEnforcement') }}
                    li {{ $t('tnc.ugc.moderate') }}
                br
                p {{ $t('tnc.ugc.visibility') }}
                br
                p(v-html="$t('tnc.ugc.report')")
                br
                p {{ $t('tnc.ugc.inApp') }}
                br
                p(v-html="$t('tnc.ugc.review')")
                br
                p {{ $t('tnc.ugc.license') }}
                br
                p {{ $t('tnc.ugc.personalData') }}
                br
                p {{ $t('tnc.ugc.modification') }}
                br
                p(v-html="$t('tnc.dataStorage')")
                div(v-if='isPhoneOs')
                    p(v-html="$t('tnc.jailbreak')")
                div(v-if='hasThirdPartyServicesSelected')
                    p {{ $t('tnc.thirdPartyTitle') }}
                    ul
                        li( v-for="item in enabledThirdPartyServicesWithTerms" :key="item.name")
                            a(:href='item.link.terms' target='_blank' rel='noopener noreferrer') {{ tpsName(item) }}
                br
                div(v-if='isMobileApp')
                    p {{ $t('tnc.mobileData') }}
                    br
                    p {{ $t('tnc.mobileCharges') }}
                div(v-if='isWebApp')
                    p {{ $t('tnc.webData') }}
                    br
                    p {{ $t('tnc.webCharges') }}
                br
                p {{ $t('tnc.battery') }}
                br
                p {{ $t('tnc.consumerRights') }}

                strong {{ $t('tnc.limitationTitle') }}
                p {{ $t('tnc.limitationText') }}
                br
                p {{ $t('tnc.limitationRetains') }}
                ul
                    li {{ $t('tnc.limitation.death') }}
                    li {{ $t('tnc.limitation.fraud') }}
                    li {{ $t('tnc.limitation.other') }}
                br
                p {{ $t('tnc.limitationCap') }}
                br
                p {{ $t('tnc.limitationThirdParty') }}
                br
                strong {{ $t('tnc.indemnificationTitle') }}
                p {{ $t('tnc.indemnificationText') }}
                br
                p {{ $t('tnc.indemnificationException') }}
                br
                div(v-if="isAIUsed")
                    p {{ $t('tnc.aiText') }}
                    br
                p {{ $t('tnc.updates') }}
                br
                strong {{ $t('tnc.governingLawTitle') }}
                br
                p {{ $t('tnc.governingLawText') }}
                br
                p {{ $t('tnc.governingLawDispute') }}
                br
                strong {{ $t('tnc.dsaTitle') }}
                br
                p {{ $t('tnc.dsaIntro') }}
                br
                p(v-html="$t('tnc.dsaPointOfContact')")
                br
                p(v-if='euRepresentative')
                    strong {{ $t('tnc.dsaEuRep') }}
                br
                p {{ $t('tnc.dsaModeration') }}
                br
                p {{ $t('tnc.dsaNotice') }}
                br
                p {{ $t('tnc.dsaDispute') }}
                br
                p(v-html="$t('tnc.dsaTransparency')")
                br
                p {{ $t('tnc.dsaNote') }}
                br
                strong {{ $t('tnc.severabilityTitle') }}
                p {{ $t('tnc.severabilityText') }}
                br
                strong {{ $t('tnc.entireAgreementTitle') }}
                p {{ $t('tnc.entireAgreementText') }}
                br
                strong {{ $t('tnc.changesTitle') }}
                p {{ $t('tnc.changesText') }}
                br
                p(v-html="$t('tnc.changesPrev')")
                br
                p(v-html="$t('tnc.effectiveDate')")
                br
                strong {{ $t('tnc.contactTitle') }}
                p(v-html="$t('tnc.contactText')")
                +attribution('Terms & Conditions')
            textarea#tandc_txtarea.textarea(:aria-label='$t("tnc.title") + $t("modal.textareaLabel")' onclick='this.focus();this.select()' readonly='readonly' v-show='contentRenderType==2')
        footer.modal-card-foot
            +outputButtons('tandc_content', 'tandc_txtarea')
            +flycricketDeploy('deployFcSimple()')
